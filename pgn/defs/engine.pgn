# Engine & Electrical PGNs

pgn 127493 "Transmission Parameters Dynamic"
pgn 127497 "Trip Parameters Engine"
pgn 127498 "Engine Parameters Static"

# PGN 127488 — Engine Parameters, Rapid Update
pgn 127488 "Engine Parameters Rapid Update" interval=100ms {
  engine_instance    uint8   :8
  engine_speed       uint16  :16  scale=0.25   unit="rpm"
  engine_boost       uint16  :16  scale=100    unit="Pa"
  engine_tilt_trim   int8    :8
  _                           :16
}

# PGN 127489 — Engine Parameters, Dynamic
pgn 127489 "Engine Parameters Dynamic" fast_packet interval=500ms {
  engine_instance          uint8   :8
  oil_pressure             uint16  :16  scale=100    unit="Pa"
  oil_temperature          uint16  :16  scale=0.1    unit="K"
  temperature              uint16  :16  scale=0.01   unit="K"
  alternator_potential     int16   :16  scale=0.01   unit="V"
  fuel_rate                int16   :16  scale=0.1    unit="L/h"
  total_engine_hours       uint32  :32  scale=1      unit="s"
  coolant_pressure         uint16  :16  scale=100    unit="Pa"
  fuel_pressure            uint16  :16  scale=1000   unit="Pa"
  _                                 :8
  discrete_status_1        uint16  :16
  discrete_status_2        uint16  :16
  percent_engine_load      int8    :8   unit="%"
  percent_engine_torque    int8    :8   unit="%"
}

# PGN 127501 — Binary Switch Bank Status
pgn 127501 "Binary Switch Bank Status" interval=1000ms {
  instance    uint8   :8
  indicator   uint8   :2  repeat=28
}

# PGN 127502 — Binary Switch Bank Control
# Same wire format as 127501. Indicator values: 0=OFF, 1=ON, 2/3=no action.
pgn 127502 "Binary Switch Bank Control" {
  instance    uint8   :8
  indicator   uint8   :2  repeat=28
}

# PGN 127505 — Fluid Level
pgn 127505 "Fluid Level" interval=2500ms {
  instance    uint8   :4
  fluid_type  uint8   :4
  level       int16   :16  scale=0.004 unit="%"
  capacity    uint32  :32  scale=0.1   unit="L"
  _                    :8
}

# PGN 127508 — Battery Status
pgn 127508 "Battery Status" interval=1500ms {
  instance       uint8   :8
  voltage        uint16  :16  scale=0.01  unit="V"
  current        int16   :16  scale=0.1   unit="A"
  temperature    uint16  :16  scale=0.01  unit="K"
  sid            uint8   :8
}

# PGN 127513 — Battery Configuration Status
pgn 127513 "Battery Configuration Status" fast_packet interval=10000ms {
  instance             uint8   :8
  battery_type         uint8   :4
  supports_equal       uint8   :2
  _                             :2
  nominal_voltage      uint16  :16  scale=0.01  unit="V"
  nominal_capacity     uint16  :16  scale=1     unit="Ah"
  temperature_coeff    uint8   :8   unit="%"
  peukert_exponent     int16   :16  scale=0.002
  charge_eff_factor    int16   :16  scale=1     unit="%"
}

# PGN 127506 — DC Detailed Status
pgn 127506 "DC Detailed Status" fast_packet interval=1500ms {
  sid                uint8   :8
  instance           uint8   :8
  dc_type            uint8   :8
  state_of_charge    uint8   :8   unit="%"
  state_of_health    uint8   :8   unit="%"
  time_remaining     uint16  :16  scale=60     unit="s"
  ripple_voltage     uint16  :16  scale=0.001  unit="V"
  capacity_remaining uint16  :16  scale=1      unit="Ah"
}

# PGN 127509 — Inverter Status
# Reports operating state of a DC-to-AC inverter. Obsolete per NMEA,
# superseded by PGN 127511, but still widely transmitted (e.g. Victron).
pgn 127509 "Inverter Status" fast_packet interval=1500ms {
  instance          uint8   :8
  ac_instance       uint8   :8
  dc_instance       uint8   :8
  operating_state   uint8   :4
  inverter_enable   uint8   :2
  _                          :2
}

# PGN 127750 — Converter Status
# Reports the state of a DC/DC or DC/AC converter (charger, inverter, or combo).
pgn 127750 "Converter Status" interval=1500ms {
  sid                    uint8   :8
  connection_number      uint8   :8
  operating_state        uint8   :8
  temperature_state      uint8   :2
  overload_state         uint8   :2
  low_dc_voltage_state   uint8   :2
  ripple_state           uint8   :2
  _                               :32
}

# PGN 127507 — Charger Status
pgn 127507 "Charger Status" interval=1500ms {
  instance             uint8   :8
  battery_instance     uint8   :8
  operating_state      uint8   :4
  charge_mode          uint8   :4
  charger_enable       uint8   :2
  equalization_pending uint8   :2
  _                             :4
  equalization_time    uint16  :16  scale=60 unit="s"
}

# PGN 127510 — Charger Configuration Status
# Field layout from canboat. Note: canboat marks this fast-packet, but the
# WS500 (and other chargers seen here) transmit it as a single 8-byte frame,
# so it is decoded as single-frame to keep fast-packet reassembly correct.
enum ChargingAlgorithm {
  0 = "trickle"
  1 = "constant_voltage_current"
  2 = "two_stage"
  3 = "three_stage"
}
enum ChargerMode {
  0 = "standalone"
  1 = "primary"
  2 = "secondary"
  3 = "echo"
}
enum ChargerEnable {
  0 = "off"
  1 = "on"
}
enum DeviceTempState {
  0 = "cold"
  1 = "warm"
  2 = "hot"
}
pgn 127510 "Charger Configuration Status" interval=1500ms {
  instance                uint8              :8
  battery_instance        uint8              :8
  charger_enable          ChargerEnable      :2
  _                                          :6
  charge_current_limit    uint8              :8   unit="%"
  charging_algorithm      ChargingAlgorithm  :4
  charger_mode            ChargerMode        :4
  estimated_temperature   DeviceTempState    :4
  equalize_one_time       ChargerEnable      :2
  over_charge_enable      ChargerEnable      :2
  equalize_time           uint16             :16  scale=60  unit="s"
}

# PGN 61444 — J1939 Electronic Engine Controller 1 (EEC1)
# Standard J1939, not NMEA 2000. The WS500 broadcasts this carrying engine
# speed (validated: matches NMEA 2000 PGN 127488 RPM from the same regulator).
# Torque fields use the J1939 -125% offset and are typically not-available
# from an alternator regulator.
pgn 61444 "Engine Controller 1 (J1939 EEC1)" interval=100ms {
  torque_mode            uint8   :4
  _                              :4
  drivers_demand_torque  uint8   :8   offset=-125  unit="%"
  actual_engine_torque   uint8   :8   offset=-125  unit="%"
  engine_speed           uint16  :16  scale=0.125  unit="rpm"
  source_address         uint8   :8
  starter_mode           uint8   :4
  _                              :4
  engine_demand_torque   uint8   :8   offset=-125  unit="%"
}
