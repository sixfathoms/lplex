{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "title": "lplex",
  "uid": "lplex-overview",
  "tags": ["lplex", "nmea2000", "can-bus"],
  "timezone": "browser",
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "title": "Frame Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(lplex_broker_head_seq[1m])",
          "legendFormat": "frames/sec"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "fps",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "Ring Buffer Utilization",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "lplex_ring_buffer_utilization",
          "legendFormat": "utilization"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      }
    },
    {
      "title": "Connections",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "targets": [
        { "expr": "lplex_active_sessions", "legendFormat": "sessions" },
        { "expr": "lplex_active_subscribers", "legendFormat": "subscribers" },
        { "expr": "lplex_active_consumers", "legendFormat": "consumers" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "title": "Devices",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "lplex_devices_total", "legendFormat": "active devices" },
        { "expr": "rate(lplex_devices_added_total[5m])", "legendFormat": "added/sec" },
        { "expr": "rate(lplex_devices_removed_total[5m])", "legendFormat": "removed/sec" }
      ]
    },
    {
      "title": "Consumer Lag",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "lplex_consumer_max_lag_seqs",
          "legendFormat": "max lag (sequences)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "red", "value": 10000 }
            ]
          }
        }
      }
    },
    {
      "title": "Bus Silence",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "time() - lplex_last_frame_timestamp_seconds",
          "legendFormat": "seconds since last frame"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 30 }
            ]
          }
        }
      }
    },
    {
      "title": "Journal Drops",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 16 },
      "targets": [
        {
          "expr": "lplex_journal_drops_total",
          "legendFormat": "total drops"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "title": "Journal Write Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "rate(lplex_journal_bytes_written_total[1m])",
          "legendFormat": "bytes/sec"
        },
        {
          "expr": "rate(lplex_journal_blocks_written_total[1m])",
          "legendFormat": "blocks/sec",
          "yaxis": 2
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps" }
      }
    },
    {
      "title": "Journal Write Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "lplex_journal_last_block_write_duration_seconds",
          "legendFormat": "last block write"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Replication Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "lplex_replication_connected",
          "legendFormat": "connected"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DISCONNECTED", "color": "red" } } },
            { "type": "value", "options": { "1": { "text": "CONNECTED", "color": "green" } } }
          ]
        }
      }
    },
    {
      "title": "Replication Lag",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "targets": [
        { "expr": "lplex_replication_live_lag_seqs", "legendFormat": "live lag" },
        { "expr": "lplex_replication_backfill_remaining_seqs", "legendFormat": "backfill remaining" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "title": "Replication Throughput",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "targets": [
        {
          "expr": "rate(lplex_replication_live_frames_sent_total[1m])",
          "legendFormat": "live frames/sec"
        },
        {
          "expr": "rate(lplex_replication_backfill_bytes_sent_total[1m])",
          "legendFormat": "backfill bytes/sec"
        }
      ]
    },
    {
      "title": "Replication Reconnects",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "targets": [
        {
          "expr": "rate(lplex_replication_reconnects_total[5m])",
          "legendFormat": "reconnects/sec"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.1 }
            ]
          }
        }
      }
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
