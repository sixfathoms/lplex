# lplex configuration
#
# Copy to ./lplex.conf or /etc/lplex/lplex.conf
# CLI flags override values set here.

# SocketCAN interface name
interface = can0

# HTTP listen port
port = 8089

# Max client buffer duration (ISO 8601)
max-buffer-duration = PT5M

# Alert when no CAN frames received for this duration (ISO 8601).
# Detects CAN bus disconnection or power issues.
# bus-silence-timeout = PT30S

# Journal recording (comment out to disable)
journal {

  # Directory for journal files (required to enable journaling)
  dir = /var/log/lplex

  # File name prefix
  prefix = nmea2k

  # Block size in bytes (power of 2, min 4096)
  block-size = 262144

  # Block compression: none, zstd, zstd-dict
  compression = zstd

  rotate {
    # Rotate after duration (ISO 8601, e.g. PT1H)
    duration = PT1H

    # Rotate after bytes (0 = disabled)
    size = 0
  }

  # Retention policy (all optional, comment out to disable)
  retention {
    # Delete files older than this (ISO 8601, e.g. P30D = 30 days)
    # max-age = P30D

    # Never delete files younger than this, unless max-size is exceeded
    # min-keep = PT24H

    # Hard size cap in bytes; delete oldest files when total exceeds this
    # max-size = 10737418240

    # Proactive archive threshold as % of max-size (1-99, default 80).
    # When total size exceeds this %, non-archived files are queued for
    # archive before hitting the hard cap. Only effective with max-size
    # and an archive command configured.
    # soft-pct = 80

    # What to do when the hard cap is hit and archives have failed:
    #   delete-unarchived  - delete files even if not archived (default)
    #   pause-recording    - stop journal writes until archives free space
    # overflow-policy = delete-unarchived
  }

  # Archive script (optional, comment out to disable)
  archive {
    # Path to archive script. Receives file paths as args, JSONL on stdin.
    # Must output JSONL with per-file status on stdout.
    # command = /usr/local/bin/archive-to-s3

    # When to archive: "on-rotate" (immediately) or "before-expire" (lazy)
    # trigger = on-rotate
  }
}
